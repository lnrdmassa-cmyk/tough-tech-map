{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "tough-tech-map.vercel.app" }],
      "destination": "https://build-deep-tech-europe.vercel.app/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "tough-tech-map.vercel.app" }],
      "destination": "https://build-deep-tech-europe.vercel.app/:path*",
      "permanent": true
    }
  ]
}
